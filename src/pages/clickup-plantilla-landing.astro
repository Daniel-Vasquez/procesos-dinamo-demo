---
export const prerender = false;

import "../styles/global.css";
import ClickupTemplateExplorer from "../components/ClickupTemplateExplorer";
import { getClickupTemplateData } from "../lib/clickup";

const data = await getClickupTemplateData();
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Plantilla Landing Dev — ClickUp</title>
	</head>
	<body>
		<ClickupTemplateExplorer client:load data={data} />
	</body>
</html>
